# =========================================================
class DiodeTester:
    def __init__(self, dev: SerialDevice):
        self.dev = dev

    def connect(self):
        self.dev.open()
        time.sleep(0.5)
        self._drain_boot()
        log_user("Nano hazır.")

    def _drain_boot(self, max_lines: int = 30):
        for _ in range(max_lines):
            line = self.dev.read_line()
            if not line:
                break
            log_full(f"[NANO BOOT] {line}")

    def test_once(self, timeout: float = 2.5):
        log_full("[NANO TX] d")
        self.dev.write_raw("d")

        lines = []
        t0 = time.time()
        while time.time() - t0 < timeout:
            line = self.dev.read_line()
            if line:
                log_full(f"[NANO RX] {line}")
                lines.append(line)
            else:
                time.sleep(0.03)

        for line in lines:
            if line.startswith("D;"):
                parsed = parse_diode_line(line)
                if parsed is not None:
                    return parsed

        raise RuntimeError("Nano diyot çıktısı parse edilemedi")

    def test_with_retry(self, retry_count: int = TEST_RETRY_COUNT, wait_s: float = TEST_RETRY_WAIT):
        last_err = None
        for i in range(retry_count):
            try:
                log_full(f"[NANO] diyot test denemesi {i+1}/{retry_count}")
                result = self.test_once()
                if is_valid_test_result(result):
                    return result
                log_full("[NANO] Geçersiz diyot çıktısı, tekrar...")
            except Exception as e:
                last_err = e
                log_full(f"[NANO] Diyot test hatası: {e}")
            time.sleep(wait_s)
        raise RuntimeError(f"Nano diyot testi başarısız. Son hata: {last_err}")

