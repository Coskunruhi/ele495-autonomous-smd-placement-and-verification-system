# DİRENÇ İŞLEME
# =========================================================
def process_one_resistor(printer: Printer, arduino: ArduinoActuator, resistor_tester: ResistorTester,
                         pick_tuple, resistor_value_to_slot_map, mode: int):
    pick_name, px, py, pz = pick_tuple
    log_full(f"\n===== DİRENÇ İŞLENİYOR: {pick_name} =====")
    log_user(f"{pick_name} alınıyor.")

    identified_code = None
    target_slot = None

    try:
        printer.go_safe_only()
        printer.move_xy(px, py)
        printer.wait_all()

        log_full(f"[INFO] Direnç alma noktasına iniliyor: Z={pz:.2f}")
        printer.move_z(pz)
        printer.wait_all()
        time.sleep(AFTER_Z_MOVE_WAIT)

        arduino.pump_on()

        log_full(f"[INFO] SAFE'e geri çıkılıyor: Z={SAFE_Z:.2f}")
        printer.move_z(SAFE_Z)
        printer.wait_all()
        time.sleep(AFTER_Z_MOVE_WAIT)

        unreadable_success = False

        for unreadable_try in range(1, UNREADABLE_RETRY_COUNT + 1):
            try:
                log_full(f"\n[INFO] Direnç okuma çevrimi {unreadable_try}/{UNREADABLE_RETRY_COUNT}")
                log_user(f"{pick_name} test ediliyor. Deneme {unreadable_try}/{UNREADABLE_RETRY_COUNT}")

                printer.go_safe_only()
                move_to_resistor_test_station(printer, arduino)

                test = resistor_tester.test_with_retry()
                measured_ohm = test["ohm"]
                log_full(f"[RES TEST RESULT] {measured_ohm:.2f} ohm | raw={test['raw']}")

                identified_code = classify_resistor(measured_ohm)

                if identified_code not in resistor_value_to_slot_map:
                    raise UnreadableMeasurementError(
                        f"Ölçülen direnç değeri ({identified_code}) kullanıcı eşleşmesinde yok"
                    )

                target_slot = resistor_value_to_slot_map[identified_code]
                unreadable_success = True
                break

            except Exception as e:
                log_full(f"[WARN] Direnç ölçümü okunamadı / doğrulanamadı: {e}")

                if unreadable_try < UNREADABLE_RETRY_COUNT:
                    return_to_pick_and_wait_for_reseat(
                        printer=printer,
                        arduino=arduino,
                        px=px,
                        py=py,
                        pz=pz,
                        offset_active=False,
                        wait_s=UNREADABLE_WAIT_S
                    )
                else:
                    log_full(f"[WARN] Direnç {pick_name} için {UNREADABLE_RETRY_COUNT} denemede de geçerli okuma alınamadı.")
                    log_user(f"{pick_name} okunamadı, geri bırakılıyor.")
                    drop_back_to_pick_and_release(
                        printer=printer,
                        arduino=arduino,
                        px=px,
                        py=py,
                        pz=pz,
                        offset_active=False
                    )
                    return None, None

        if not unreadable_success or identified_code is None or target_slot is None:
            log_full(f"[WARN] {pick_name} atlanıyor.")
            return None, None

        log_full("[INFO] Test bitti, SAFE'e çıkılıyor.")
        printer.move_z(SAFE_Z)
        printer.wait_all()
        time.sleep(AFTER_Z_MOVE_WAIT)

        arduino.pump_force_on()
        log_full(f"[INFO] Ölçülen değer {identified_code} -> hedef slot {target_slot}")
        log_user(f"{identified_code} kodlu direnç {target_slot} slotuna gönderiliyor.")
        place_component(printer, arduino, mode, target_slot, offset_active=False)

    except Exception as e:
        log_full(f"[RES FAIL] {pick_name}: {e}")
        log_user(f"{pick_name} işlenirken hata oluştu.")
        try:
            drop_back_to_pick_and_release(
                printer=printer,
                arduino=arduino,
                px=px,
                py=py,
                pz=pz,
                offset_active=False
            )
        except Exception as drop_err:
            log_full(f"[WARN] Direnç geri bırakma sırasında hata: {drop_err}")
        identified_code = None
        target_slot = None

    return identified_code, target_slot

