# ORTAK BIRAKMA
# =========================================================
def place_component(printer: Printer, arduino: ArduinoActuator,
                    mode: int, slot_name: str, offset_active: bool = False):
    slot_coords = get_slot_coords(mode)
    tx, ty, tz = slot_coords[slot_name]
    tx, ty = apply_rotation_xy_offset(tx, ty, offset_active)

    log_full(f"[INFO] {slot_name} slotuna gidiliyor: X={tx:.2f}, Y={ty:.2f}, Z={tz:.2f} | mode={mode} | offset_active={offset_active}")
    log_user(f"{slot_name} slotuna yerleştirme yapılıyor.")

    arduino.pump_force_on()

    printer.go_safe_only()
    printer.move_xy(tx, ty)
    printer.wait_all()
    time.sleep(AFTER_SLOT_XY_WAIT)

    arduino.pump_force_on()

    log_full(f"[INFO] Slot yüksekliğine iniliyor: Z={tz:.2f}")
    printer.move_z(tz)
    printer.wait_all()
    time.sleep(AFTER_SLOT_Z_DOWN_WAIT)

    log_full(f"[INFO] Slotta sabit bekleniyor: {SLOT_DWELL_MS_BEFORE_DROP} ms")
    printer.dwell_ms(SLOT_DWELL_MS_BEFORE_DROP)

    printer.wait_all()
    printer.flush_rx(PRINTER_FLUSH_BEFORE_DROP_S)

    arduino.pump_off()
    log_full("[INFO] Vakum kapandı, parçanın ayrılması bekleniyor...")
    time.sleep(RELEASE_WAIT_AFTER_PUMP_OFF)

    first_lift_z = min(tz + RELEASE_LIFT_Z, SAFE_Z)
    log_full(f"[INFO] İlk güvenli kalkış: Z={first_lift_z:.2f}")
    printer.move_z(first_lift_z)
    printer.wait_all()
    time.sleep(RELEASE_LIFT_WAIT)

    printer.move_z(SAFE_Z)
    printer.wait_all()
    time.sleep(AFTER_Z_MOVE_WAIT)

    log_full("[INFO] Parça bırakma tamamlandı.")
    log_user(f"{slot_name} slotuna yerleştirme tamamlandı.")

# =========================================================
# DİYOT İŞLEME
# =========================================================
def process_one_diode(printer: Printer, arduino: ArduinoActuator, diode_tester: DiodeTester, pick_tuple, diode_slot_map, mode: int):
    pick_name, px, py, pz = pick_tuple
    log_full(f"\n===== DİYOT İŞLENİYOR: {pick_name} =====")
    log_user(f"{pick_name} alınıyor.")

    did_rotate = False
    diode_type = None
    rotation_offset_active = False

    try:
        printer.go_safe_only()
        printer.move_xy(px, py)
        printer.wait_all()

        log_full(f"[INFO] Diyot alma noktasına iniliyor: Z={pz:.2f}")
        printer.move_z(pz)
        printer.wait_all()
        time.sleep(AFTER_Z_MOVE_WAIT)

        arduino.pump_on()

        log_full(f"[INFO] SAFE'e geri çıkılıyor: Z={SAFE_Z:.2f}")
        printer.move_z(SAFE_Z)
        printer.wait_all()
        time.sleep(AFTER_Z_MOVE_WAIT)

        unreadable_success = False

        for unreadable_try in range(1, UNREADABLE_RETRY_COUNT + 1):
            try:
                log_full(f"\n[INFO] Diyot okuma çevrimi {unreadable_try}/{UNREADABLE_RETRY_COUNT}")
                log_user(f"{pick_name} test ediliyor. Deneme {unreadable_try}/{UNREADABLE_RETRY_COUNT}")

                printer.go_safe_only()
                move_to_diode_test_station(printer, arduino, offset_active=rotation_offset_active)

                test = diode_tester.test_with_retry()
                log_full(f"[DIODE TEST RESULT] {test}")

                if direction_is_correct(test):
                    log_user("Diyot yönü doğru.")
                    diode_type = classify_diode(test)
                    unreadable_success = True
                    break

                log_full("[INFO] Diyot ters algılandı, SAFE'e çıkılıp çevrilecek.")
                log_user("Diyot yönü ters algılandı.")
                printer.move_z(SAFE_Z)
                printer.wait_all()
                time.sleep(AFTER_Z_MOVE_WAIT)

                arduino.rotate_fwd_180()
                did_rotate = True
                rotation_offset_active = True

                log_full(f"[INFO] Rotate oldu. Offset: X={ROTATED_X_OFFSET}, Y={ROTATED_Y_OFFSET}")

                printer.go_safe_only()
                move_to_diode_test_station(printer, arduino, offset_active=True)

                test = diode_tester.test_with_retry()
                log_full(f"[DIODE RETEST RESULT] {test}")

                if not direction_is_correct(test):
                    raise UnreadableMeasurementError("Döndürmeden sonra da diyot yönü okunamadı/doğrulanamadı")

                log_user("Döndürme sonrası yön doğru.")
                diode_type = classify_diode(test)
                unreadable_success = True
                break

            except Exception as e:
                log_full(f"[WARN] Diyot ölçümü okunamadı / doğrulanamadı: {e}")

                if did_rotate:
                    log_full("[INFO] Yeniden deneme öncesi mekanizma eski yönüne alınıyor...")
                    printer.go_safe_only()
                    arduino.rotate_back_180()
                    did_rotate = False
                    rotation_offset_active = False

                if unreadable_try < UNREADABLE_RETRY_COUNT:
                    return_to_pick_and_wait_for_reseat(
                        printer=printer,
                        arduino=arduino,
                        px=px,
                        py=py,
                        pz=pz,
                        offset_active=False,
                        wait_s=UNREADABLE_WAIT_S
                    )
                else:
                    log_full(f"[WARN] Diyot {pick_name} için {UNREADABLE_RETRY_COUNT} denemede de geçerli okuma alınamadı.")
                    log_user(f"{pick_name} okunamadı, geri bırakılıyor.")
                    drop_back_to_pick_and_release(
                        printer=printer,
                        arduino=arduino,
                        px=px,
                        py=py,
                        pz=pz,
                        offset_active=False
                    )
                    return None

        if not unreadable_success or diode_type is None:
            log_full(f"[WARN] {pick_name} atlanıyor.")
            return None

        log_full("[INFO] Test bitti, SAFE'e çıkılıyor.")
        printer.move_z(SAFE_Z)
        printer.wait_all()
        time.sleep(AFTER_Z_MOVE_WAIT)

        arduino.pump_force_on()
        target_slot = diode_slot_map[diode_type]
        log_full(f"[INFO] {diode_type} -> {target_slot}")
        log_user(f"{diode_type} tipi {target_slot} slotuna gönderiliyor.")

        place_component(printer, arduino, mode, target_slot, offset_active=rotation_offset_active)

    except Exception as e:
        log_full(f"[DIODE FAIL] {pick_name}: {e}")
        log_user(f"{pick_name} işlenirken hata oluştu.")
        try:
            drop_back_to_pick_and_release(
                printer=printer,
                arduino=arduino,
                px=px,
                py=py,
                pz=pz,
                offset_active=rotation_offset_active
            )
        except Exception as drop_err:
            log_full(f"[WARN] Diyot geri bırakma sırasında hata: {drop_err}")
        diode_type = None

    finally:
        if did_rotate:
            try:
                printer.go_safe_only()
                arduino.rotate_back_180()
            except Exception as rot_err:
                log_full(f"[WARN] rotate_back_180 hatası: {rot_err}")

    return diode_type

