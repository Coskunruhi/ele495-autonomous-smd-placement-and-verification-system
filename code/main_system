def return_to_pick_and_wait_for_reseat(printer: Printer, arduino: ArduinoActuator,
                                       px: float, py: float, pz: float,
                                       offset_active: bool,
                                       wait_s: float = UNREADABLE_WAIT_S):
    wait_x, wait_y = apply_rotation_xy_offset(px, py, offset_active)

    log_full("[INFO] Ölçüm okunamadı. Parça vakum açık şekilde pick lokasyonuna geri götürülüyor...")
    log_user("Ölçüm okunamadı, parça düzeltme için geri götürülüyor.")
    arduino.pump_force_on()

    printer.go_safe_only()
    printer.move_xy(wait_x, wait_y)
    printer.wait_all()

    log_full("[INFO] Z havada tutuluyor, kullanıcı düzeltmesi için aşağı inilmiyor.")
    arduino.pump_force_on()

    show_user_warning(USER_WARNING_TEXT)
    log_full(f"[INFO] Kullanıcı müdahalesi için {wait_s:.1f} sn bekleniyor...")
    time.sleep(wait_s)

    log_full(f"[INFO] Bekleme bitti. Yeniden almak için aşağı iniliyor: Z={pz:.2f}")
    arduino.pump_force_on()
    printer.move_z(pz)
    printer.wait_all()
    time.sleep(AFTER_Z_MOVE_WAIT)

    log_full("[INFO] Parça tekrar alınsın diye kısa süre bekleniyor...")
    time.sleep(PUMP_PICK_WAIT)

    log_full(f"[INFO] Tekrar SAFE yüksekliğine çıkılıyor: Z={SAFE_Z:.2f}")
    printer.move_z(SAFE_Z)
    printer.wait_all()
    time.sleep(AFTER_Z_MOVE_WAIT)

def drop_back_to_pick_and_release(printer: Printer, arduino: ArduinoActuator,
                                  px: float, py: float, pz: float,
                                  offset_active: bool):
    drop_x, drop_y = apply_rotation_xy_offset(px, py, offset_active)

    log_full("[INFO] Parça pick noktasına geri bırakılıyor...")
    log_user("Parça geri bırakılıyor.")
    printer.go_safe_only()
    printer.move_xy(drop_x, drop_y)
    printer.wait_all()

    log_full(f"[INFO] Geri bırakmak için aşağı iniliyor: Z={pz:.2f}")
    printer.move_z(pz)
    printer.wait_all()
    time.sleep(AFTER_Z_MOVE_WAIT)

    arduino.pump_off()
    time.sleep(RELEASE_WAIT_AFTER_PUMP_OFF)

    printer.move_z(min(pz + 1.5, SAFE_Z))
    printer.wait_all()
    time.sleep(RELEASE_LIFT_WAIT)

    printer.move_z(SAFE_Z)
    printer.wait_all()
    time.sleep(AFTER_Z_MOVE_WAIT)

def move_to_diode_test_station(printer: Printer, arduino: ArduinoActuator, offset_active: bool = False):
    arduino.pump_force_on()

