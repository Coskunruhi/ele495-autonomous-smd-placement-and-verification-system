def choose_mode():
    while True:
        print("\n=== MOD SEÇİMİ ===")
        print("1 -> 2 diyot + 2 direnç")
        print("2 -> 4 direnç")
        print("q -> çıkış")
        s = input("Seçim: ").strip().lower()
        if s in ("1", "2", "q"):
            return s
        print("Geçersiz seçim.")

def choose_from_list(prompt, options):
    while True:
        print(f"\n{prompt}")
        for i, item in enumerate(options, start=1):
            print(f"{i} -> {item}")
        s = input("Seçim: ").strip()
        if not s.isdigit():
            print("Geçersiz seçim.")
            continue
        idx = int(s) - 1
        if 0 <= idx < len(options):
            return options[idx]
        print("Geçersiz seçim.")

def get_diode_slot_mapping():
    print("\n=== DİYOT SLOT EŞLEŞMESİ ===")
    d1_choice = choose_from_list("D1 slotuna hangi diyot gitsin?", ["S3M", "SK510C"])
    d2_choice = "SK510C" if d1_choice == "S3M" else "S3M"
    print(f"D2 slotuna otomatik {d2_choice} atanacak.")
    return {
        d1_choice: "D1",
        d2_choice: "D2",
    }

def get_resistor_value_to_slot_mapping_mode1():
    print("\n=== MOD 1 DİRENÇ EŞLEŞMESİ ===")
    available = ["223", "331", "1001", "332"]
    mapping = {}

    choice_r1 = choose_from_list("R1 slotuna hangi direnç değeri gitsin?", available)
    mapping[choice_r1] = "R1"
    available.remove(choice_r1)

    choice_r2 = choose_from_list("R2 slotuna hangi direnç değeri gitsin?", available)
    mapping[choice_r2] = "R2"
    available.remove(choice_r2)

    return mapping

def get_resistor_value_to_slot_mapping_mode2():
    print("\n=== MOD 2 DİRENÇ EŞLEŞMESİ ===")
    available = ["223", "331", "1001", "332"]
    mapping = {}

    for slot in ["D1", "D2", "R1", "R2"]:
        choice = choose_from_list(f"{slot} slotuna hangi direnç değeri gitsin?", available)
        mapping[choice] = slot
        available.remove(choice)

    return mapping

