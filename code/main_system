# =========================================================
# PARSE / KARAR
# =========================================================
def parse_diode_line(line: str):
    m = re.search(r"V1=(\d+);V2=(\d+);DIFF=(\d+);RES=(.+)$", line)
    if not m:
        return None
    return {
        "v1": int(m.group(1)),
        "v2": int(m.group(2)),
        "diff": int(m.group(3)),
        "res": m.group(4).strip(),
        "raw": line
    }

def parse_resistor_ohm(line: str):
    patterns = [
        r"RX\s*=\s*([0-9]+(?:\.[0-9]+)?)",
        r"R\s*=\s*([0-9]+(?:\.[0-9]+)?)",
        r"R\s*:\s*([0-9]+(?:\.[0-9]+)?)",
        r"RES\s*=\s*([0-9]+(?:\.[0-9]+)?)",
        r"OHM\s*=\s*([0-9]+(?:\.[0-9]+)?)",
        r"([0-9]+(?:\.[0-9]+)?)\s*OHM",
        r"^([0-9]+(?:\.[0-9]+)?)$",
    ]
    for pat in patterns:
        m = re.search(pat, line, flags=re.IGNORECASE)
        if m:
            return float(m.group(1))
    return None

def is_valid_test_result(test_result: dict) -> bool:
    if not test_result:
        return False

    res = test_result.get("res", "")
    v1 = test_result.get("v1", -1)
    v2 = test_result.get("v2", -1)
    diff = test_result.get("diff", -1)

    if not (("FWD_TEST1" in res) or ("FWD_TEST2" in res)):
        return False

    if v1 < 0 or v2 < 0 or diff < 0:
        return False

    if diff < 2000:
        return False

    return True

def direction_is_correct(test_result: dict) -> bool:
    return "FWD_TEST2" in test_result["res"]

def classify_diode(test_result: dict) -> str:
    v1   = test_result["v1"]
    v2   = test_result["v2"]
    diff = test_result["diff"]
    res  = test_result["res"]

    log_full(f"[CLASSIFY-DIODE] v1={v1}, v2={v2}, diff={diff}, res={res}")

    # =====================================================
    # DİYOT MERKEZ DEĞERLERİ
    # =====================================================
    # SK510C ölçümleri
    # FWD_TEST1:
    #   v1 ≈ 2732-2733
    #   diff ≈ 2732-2733
    # FWD_TEST2:
    #   v2 ≈ 2243-2277
    #   diff ≈ 2719-2752

    # S3M ölçümleri
    # FWD_TEST1:
    #   v1 ≈ 2903-2925
    #   diff ≈ 2903-2925
    # FWD_TEST2:
    #   v2 ≈ 2141-2164
    #   diff ≈ 2831-2854

    SK_T1_V1_CENTER   = 2733
    SK_T1_DIFF_CENTER = 2733

    S3M_T1_V1_CENTER   = 2915
    S3M_T1_DIFF_CENTER = 2915

    SK_T2_V2_CENTER   = 2257
    SK_T2_DIFF_CENTER = 2735

    S3M_T2_V2_CENTER   = 2150
    S3M_T2_DIFF_CENTER = 2842

    # Skorlar çok yakınsa yanlış karar vermek yerine retry'e düşsün
    UNSURE_GAP = 10

    if "FWD_TEST1" in res:
        # TEST1 için v1 + diff çok iyi ayırıyor
        sk_score  = abs(v1 - SK_T1_V1_CENTER)  + abs(diff - SK_T1_DIFF_CENTER)
        s3m_score = abs(v1 - S3M_T1_V1_CENTER) + abs(diff - S3M_T1_DIFF_CENTER)

        log_full(f"[CLASSIFY-DIODE] TEST1 skor -> SK510C={sk_score}, S3M={s3m_score}")

    elif "FWD_TEST2" in res:
        # TEST2 için v1 ayırıcı değil, o yüzden v2 + diff kullanıyoruz
        sk_score  = abs(v2 - SK_T2_V2_CENTER)  + abs(diff - SK_T2_DIFF_CENTER)
        s3m_score = abs(v2 - S3M_T2_V2_CENTER) + abs(diff - S3M_T2_DIFF_CENTER)

        log_full(f"[CLASSIFY-DIODE] TEST2 skor -> SK510C={sk_score}, S3M={s3m_score}")

    else:
        raise RuntimeError(f"Sınıflandırma için yön bilgisi yok: {res}")

    score_gap = abs(sk_score - s3m_score)
    if score_gap < UNSURE_GAP:
        raise RuntimeError(
            f"Diyot tipi sınır bölgede kaldı. "
            f"SK510C skor={sk_score}, S3M skor={s3m_score}, fark={score_gap}"
        )

    diode_type = "SK510C" if sk_score < s3m_score else "S3M"

    log_full(f"[INFO] Diyot tipi belirlendi: {diode_type}")
    log_user(f"Diyot tipi ölçüldü: {diode_type}")
    return diode_type

def resistor_in_range(measured_ohm: float, nominal_ohm: float, tol: float = RESISTOR_TOLERANCE) -> bool:
    low = nominal_ohm * (1.0 - tol)
    high = nominal_ohm * (1.0 + tol)
    return low <= measured_ohm <= high

def classify_resistor(measured_ohm: float):
    log_full(f"[CLASSIFY-RES] measured={measured_ohm:.2f} ohm")
    matches = []
    for code, nominal in RESISTOR_TARGETS.items():
        if resistor_in_range(measured_ohm, nominal):
            matches.append(code)

    if len(matches) == 1:
        log_full(f"[INFO] Direnç tipi belirlendi: {matches[0]}")
        log_user(f"Direnç ölçüldü: {matches[0]}")
        return matches[0]
    if len(matches) > 1:
        raise RuntimeError(f"Direnç birden fazla tipe uydu: {matches}")
    raise RuntimeError(f"Direnç değeri hiçbir hedefe uymadı: {measured_ohm:.2f} ohm")

def apply_rotation_xy_offset(x: float, y: float, offset_active: bool):
    if offset_active:
        return x + ROTATED_X_OFFSET, y + ROTATED_Y_OFFSET
    return x, y

