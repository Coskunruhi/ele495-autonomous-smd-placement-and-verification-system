# 3D PRINTER
# =========================================================
class Printer:
    def __init__(self, dev: SerialDevice):
        self.dev = dev

    def connect(self):
        self.dev.open()
        time.sleep(0.5)
        self._drain_boot()
        self.send("G90")
        self.send("G21")
        self.send("M17")
        log_user("Printer hazır.")

    def _drain_boot(self, max_lines: int = 25):
        for _ in range(max_lines):
            line = self.dev.read_line()
            if not line:
                break
            log_full(f"[PRINTER BOOT] {line}")

    def flush_rx(self, duration_s: float = 0.5):
        log_full(f"[INFO] Printer RX flush: {duration_s:.2f}s")
        t0 = time.time()
        while time.time() - t0 < duration_s:
            line = self.dev.read_line()
            if line:
                log_full(f"[PRINTER RX FLUSH] {line}")
            else:
                time.sleep(0.02)

    def send(self, gcode: str, timeout: float = None):
        if timeout is None:
            cmd = gcode.strip().split()[0].upper() if gcode.strip() else ""
            if cmd in ("G0", "G1"):
                timeout = 30.0
            elif cmd == "M400":
                timeout = 60.0
            elif cmd == "G4":
                timeout = 20.0
            else:
                timeout = 10.0

        log_full(f"[PRINTER TX] {gcode}")
        self.dev.write_line(gcode)

        t0 = time.time()
        while True:
            line = self.dev.read_line()
            if line:
                log_full(f"[PRINTER RX] {line}")
                ll = line.lower()
                if "ok" in ll:
                    return
                if "error" in ll:
                    raise RuntimeError(f"Printer error: {line}")

            if time.time() - t0 > timeout:
                raise TimeoutError(f"Printer timeout ({timeout}s): {gcode}")

    def wait_all(self):
        self.send("M400")

    def dwell_ms(self, ms: int):
        self.send(f"G4 P{int(ms)}")

    def move_xy(self, x: float, y: float, feed: int = FEED_XY):
        self.send(f"G0 X{x:.3f} Y{y:.3f} F{feed}")

    def move_z(self, z: float, feed: int = FEED_Z):
        self.send(f"G0 Z{z:.3f} F{feed}")

    def go_safe_only(self):
        log_full(f"[INFO] SAFE noktasına gidiliyor: Z={SAFE_Z:.2f}")
        log_user("Güvenli yüksekliğe çıkılıyor.")
        self.move_z(SAFE_Z)
        self.wait_all()
        time.sleep(0.5)

    def go_home(self):
        log_full(f"[INFO] HOME noktasına gidiliyor: X={HOME_X:.2f}, Y={HOME_Y:.2f}, Z={SAFE_Z:.2f}")
        log_user("HOME noktasına gidiliyor.")
        self.move_z(SAFE_Z)
        self.wait_all()
        self.move_xy(HOME_X, HOME_Y)
        self.wait_all()
        time.sleep(0.5)

