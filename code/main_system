# =========================================================
def run_mode_1(printer, arduino, diode_tester, resistor_tester):
    log_full("\n######## MOD 1: 2 DİYOT + 2 DİRENÇ ########")
    diode_slot_map = get_diode_slot_mapping()
    resistor_value_to_slot_map = get_resistor_value_to_slot_mapping_mode1()

    results = {
        "diodes": [],
        "resistors": []
    }

    for pick in DIODE_PICK_LIST:
        dtype = process_one_diode(printer, arduino, diode_tester, pick, diode_slot_map, mode=1)
        results["diodes"].append((pick[0], dtype))

    for pick in RESISTOR_PICK_LIST[:2]:
        identified_code, slot = process_one_resistor(
            printer, arduino, resistor_tester,
            pick_tuple=pick,
            resistor_value_to_slot_map=resistor_value_to_slot_map,
            mode=1
        )
        results["resistors"].append((pick[0], identified_code, slot))

    return results

def run_mode_2(printer, arduino, resistor_tester):
    log_full("\n######## MOD 2: 4 DİRENÇ ########")
    resistor_value_to_slot_map = get_resistor_value_to_slot_mapping_mode2()

    results = {
        "resistors": []
    }

    for pick in RESISTOR_PICK_LIST:
        identified_code, slot = process_one_resistor(
            printer, arduino, resistor_tester,
            pick_tuple=pick,
            resistor_value_to_slot_map=resistor_value_to_slot_map,
            mode=2
        )
        results["resistors"].append((pick[0], identified_code, slot))

    return results

