# ARDUINO
# =========================================================
class ArduinoActuator:
    def __init__(self, dev: SerialDevice):
        self.dev = dev

    def connect(self):
        self.dev.open()
        time.sleep(0.5)
        self._drain_boot()
        log_user("Arduino hazır.")

    def _drain_boot(self, max_lines: int = 20):
        for _ in range(max_lines):
            line = self.dev.read_line()
            if not line:
                break
            log_full(f"[ARDUINO BOOT] {line}")

    def _send_char(self, c: str, wait_s: float):
        log_full(f"[ARDUINO TX] {c}")
        self.dev.write_raw(c)
        t0 = time.time()
        while time.time() - t0 < wait_s:
            line = self.dev.read_line()
            if line:
                log_full(f"[ARDUINO RX] {line}")

    def pump_on(self):
        log_full("[INFO] Vakum açılıyor...")
        log_user("Vakum açılıyor.")
        self._send_char("P", wait_s=0.6)
        time.sleep(PUMP_PICK_WAIT)

    def pump_force_on(self):
        log_full("[INFO] Vakum FORCE-ON (P) gönderiliyor...")
        self._send_char("P", wait_s=0.2)

    def pump_off(self):
        log_full("[INFO] Vakum kapatılıyor...")
        log_user("Vakum kapatılıyor.")
        self._send_char("O", wait_s=0.6)
        time.sleep(0.2)

    def rotate_fwd_180(self):
        log_full("[INFO] Diyot 180 derece çevriliyor...")
        log_user("Diyot yönü ters, 180 derece çevriliyor.")
        self._send_char("F", wait_s=4.2)
        time.sleep(AFTER_ROTATE_WAIT)

    def rotate_back_180(self):
        log_full("[INFO] Mekanizma eski yönüne alınıyor...")
        self._send_char("B", wait_s=4.2)
        time.sleep(AFTER_ROTATE_WAIT)

