# =========================================================
def read_calibration_mode(mode: int):
    calib_path = get_placement_calib_json(mode)

    if not os.path.exists(calib_path):
        return None

    with open(calib_path, "r", encoding="utf-8") as f:
        data = json.load(f)

    return data.get("board_mode")

# =========================================================
# YERLEŞTİRME DOĞRULAMA ÇAĞIR
# =========================================================
def run_placement_verification(mode: int):
    requested_board_mode = "2d2r" if mode == 1 else "4r"
    calib_json_path = get_placement_calib_json(mode)

    log_full(f"\n[INFO] Yerleştirme doğrulama başlatılıyor... requested_board_mode={requested_board_mode}")
    log_user("Yerleştirme doğrulaması başlatılıyor.")

    calib_mode = read_calibration_mode(mode)
    if calib_mode is None:
        raise RuntimeError(
            f"Kalibrasyon dosyası bulunamadı: {calib_json_path}\n"
            f"Önce şu komutla kalibrasyon yap:\n"
            f"{PLACEMENT_VERIFIER_PYTHON} {PLACEMENT_VERIFIER_PY} --mode calibrate --board-mode {requested_board_mode}"
        )

    log_full(f"[INFO] Kalibrasyon dosyasındaki mod: {calib_mode}")

    if calib_mode != requested_board_mode:
        raise RuntimeError(
            f"Kalibrasyon modu ile sistem modu farklı.\n"
            f"- Sistem şu an: {requested_board_mode}\n"
            f"- Kalibrasyon dosyası: {calib_mode}\n\n"
            f"Doğru çözüm: mevcut mod için yeniden kalibrasyon yap.\n"
            f"Örnek komut:\n"
            f"{PLACEMENT_VERIFIER_PYTHON} {PLACEMENT_VERIFIER_PY} --mode calibrate --board-mode {requested_board_mode}"
        )

    cmd = [
        PLACEMENT_VERIFIER_PYTHON,
        PLACEMENT_VERIFIER_PY,
        "--mode", "verify",
        "--board-mode", requested_board_mode,
        "--auto-capture",
    ]

    log_full("[VERIFY CMD] " + " ".join(cmd))
    proc = subprocess.run(cmd)
    log_full(f"[VERIFY EXIT CODE] {proc.returncode}")

    if proc.returncode != 0:
        raise RuntimeError(f"placement_verifier verify başarısız. exit_code={proc.returncode}")

    if not os.path.exists(PLACEMENT_RESULT_JSON):
        raise RuntimeError(f"Doğrulama sonucu oluşmadı: {PLACEMENT_RESULT_JSON}")

    with open(PLACEMENT_RESULT_JSON, "r", encoding="utf-8") as f:
        result = json.load(f)

    log_full("\n=========== YERLEŞTİRME DOĞRULAMA SONUCU ===========")
    log_full(f"Overall Accuracy: %{result.get('overall_accuracy', 0.0)}")
    log_user(f"Genel doğruluk: %{result.get('overall_accuracy', 0.0)}")

    slots = result.get("slots", {})

    if mode == 1:
        slot_order = ["D1", "D2", "R1", "R2"]
    else:
        slot_order = ["D1", "D2", "R1", "R2"]

    for slot_name in slot_order:
        if slot_name in slots:
            info = slots[slot_name]
            log_full(
                f"  - {slot_name}: "
                f"present={info.get('present')} | "
                f"status={info.get('status')} | "
                f"score=%{info.get('score')} | "
                f"pos_error_px={info.get('pos_error_px')} | "
                f"angle_error_deg={info.get('angle_error_deg')}"
            )

    log_full(f"[INFO] Debug görsel: {PLACEMENT_DEBUG_IMG}")
    log_user("Doğrulama görseli hazır.")
    return result

# =========================================================
# SONUÇ YAZDIR
# =========================================================
def print_summary(mode, results):
    log_full("\n================ SONUÇ =================")
    log_full(f"Mod: {mode}")

    if "diodes" in results:
        log_full("\n[DİYOTLAR]")
        for pick_name, dtype in results["diodes"]:
            log_full(f"  - {pick_name}: {dtype}")

    if "resistors" in results:
        log_full("\n[DİRENÇLER]")
        for pick_name, identified, slot in results["resistors"]:
            log_full(f"  - {pick_name} -> Ölçülen: {identified} | Yerleşen slot: {slot}")

# =========================================================
# TEK ÇEVRİM ÇALIŞTIR
# =========================================================
def run_one_cycle(printer, arduino, diode_tester, resistor_tester, mode_str: str):
    mode = int(mode_str)
    results = {"diodes": [], "resistors": []}
    run_error = None

    log_full("[INFO] Başlangıç güvenliği: önce SAFE noktasına çıkılıyor...")
    try:
        printer.go_safe_only()
    except Exception as e:
        log_full(f"[WARN] SAFE'e çıkarken hata: {e}")

    try:
        if mode == 1:
            results = run_mode_1(printer, arduino, diode_tester, resistor_tester)
        else:
            results = run_mode_2(printer, arduino, resistor_tester)
    except Exception as e:
        run_error = e
        log_full(f"[RUN MODE ERROR] {e}")

    log_full("[INFO] Montaj sonrası doğrulama öncesi HOME'a gidilmeye çalışılıyor...")
    try:
        printer.go_home()
    except Exception as e:
        log_full(f"[WARN] HOME hatası: {e}")

    try:
        print_summary(mode, results)
    except Exception as e:
        log_full(f"[WARN] Summary hatası: {e}")

    log_full("[INFO] Şimdi yerleştirme doğrulaması başlatılacak...")
    placement_result = run_placement_verification(mode)
    log_full(f"[INFO] Final overall placement accuracy: %{placement_result.get('overall_accuracy', 0.0)}")

    if run_error is not None:
        raise RuntimeError(f"Montaj akışında hata vardı ama verify yine çalıştırıldı. Hata: {run_error}")

# =========================================================
# WEB'DEN ÇALIŞAN ÇEVRİM
# =========================================================
def run_one_cycle_web(printer, arduino, diode_tester, resistor_tester, config: dict):
    mode = int(config["mode"])

    results = {"diodes": [], "resistors": []}

    log_full("[INFO] Başlangıç güvenliği: önce SAFE noktasına çıkılıyor...")
    try:
        printer.go_safe_only()
    except Exception as e:
        log_full(f"[WARN] SAFE'e çıkarken hata: {e}")

    if mode == 1:
        diode_slot_map = config["diode_slot_map"]
        resistor_value_to_slot_map = config["resistor_map_mode1"]

        log_user("Mod 1 başlatıldı: 2 diyot + 2 direnç")

        for pick in DIODE_PICK_LIST:
            dtype = process_one_diode(printer, arduino, diode_tester, pick, diode_slot_map, mode=1)
            results["diodes"].append((pick[0], dtype))

        for pick in RESISTOR_PICK_LIST[:2]:
            identified_code, slot = process_one_resistor(
                printer, arduino, resistor_tester,
                pick_tuple=pick,
                resistor_value_to_slot_map=resistor_value_to_slot_map,
                mode=1
            )
            results["resistors"].append((pick[0], identified_code, slot))

    else:
        resistor_value_to_slot_map = config["resistor_map_mode2"]

        log_user("Mod 2 başlatıldı: 4 direnç")

        for pick in RESISTOR_PICK_LIST:
            identified_code, slot = process_one_resistor(
                printer, arduino, resistor_tester,
                pick_tuple=pick,
                resistor_value_to_slot_map=resistor_value_to_slot_map,
                mode=2
            )
            results["resistors"].append((pick[0], identified_code, slot))

    log_full("[INFO] Montaj sonrası HOME'a gidilmeye çalışılıyor...")
    try:
        printer.go_home()
    except Exception as e:
        log_full(f"[WARN] HOME hatası: {e}")

    print_summary(mode, results)
    placement_result = run_placement_verification(mode)
    log_user(f"Yerleştirme doğrulaması tamamlandı. Accuracy = %{placement_result.get('overall_accuracy', 0.0)}")

    return {
        "mode": mode,
        "results": results,
        "placement_result": placement_result
    }

# =========================================================
# MAIN
# =========================================================
def main():
    printer_dev = SerialDevice(PRINTER_PORT, PRINTER_BAUD, timeout=0.2)
    arduino_dev = SerialDevice(ARDUINO_PORT, ARDUINO_BAUD, timeout=1.0)
    nano_dev    = SerialDevice(NANO_PORT, NANO_BAUD, timeout=1.0)

    try:
        printer = Printer(printer_dev)
        arduino = ArduinoActuator(arduino_dev)
        diode_tester = DiodeTester(nano_dev)
        resistor_tester = ResistorTester(nano_dev)

        print("Cihazlara bağlanılıyor...")
        printer.connect()
        arduino.connect()
        diode_tester.connect()
        resistor_tester.connect()

        while True:
            secim = choose_mode()

            if secim == "q":
                print("\n[INFO] Kullanıcı çıkış istedi. Sistem kapatılıyor...")
                try:
                    printer.go_home()
                except Exception as e:
                    print(f"[WARN] Home'a giderken hata: {e}")
                break

            try:
                run_one_cycle(printer, arduino, diode_tester, resistor_tester, secim)
                print("\n[INFO] İşlem tamamlandı. Menüye geri dönülüyor...")
            except Exception as e:
                print(f"\n[RUN HATASI] {e}")
                print("[INFO] Sistem güvenli konuma alınmaya çalışılıyor...")
                try:
                    printer.go_safe_only()
                    printer.go_home()
                except Exception as home_err:
                    print(f"[WARN] Güvenli konuma dönüşte hata: {home_err}")

    except KeyboardInterrupt:
        print("\nKullanıcı durdurdu.")
    except Exception as e:
        print(f"\nHATA: {e}")
    finally:
        try:
            printer_dev.close()
        except Exception:
            pass
        try:
            arduino_dev.close()
        except Exception:
            pass
        try:
            nano_dev.close()
        except Exception:
            pass

if __name__ == "__main__":
    main()
