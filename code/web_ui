@app.route("/")
def index():
    return render_template_string(HTML_PAGE)

@app.route("/start", methods=["POST"])
def start():
    data = request.get_json(force=True)

    with LOCK:
        if STATE["running"]:
            return jsonify({"ok": False, "message": "Sistem zaten çalışıyor."})

    try:
        validate_config(data)
    except Exception as e:
        return jsonify({"ok": False, "message": f"Konfigürasyon hatası: {e}"})

    reset_state_for_new_run(data)
    t = threading.Thread(target=run_cycle_background, args=(data,), daemon=True)
    t.start()

    return jsonify({"ok": True, "message": "Sistem başlatıldı."})

