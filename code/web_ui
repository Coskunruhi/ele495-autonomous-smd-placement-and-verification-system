from flask import Flask, request, jsonify, send_file, render_template_string
import threading
import os
import traceback

import main_system as ms

app = Flask(__name__)

STATE = {
    "running": False,
    "full_logs": [],
    "user_logs": [],
    "current_config": None,
    "result_image_ready": False,
    "result_summary": None,
    "popup_open": False
}

LOCK = threading.Lock()

def add_full_log(msg: str):
    with LOCK:
        STATE["full_logs"].append(msg)
        STATE["full_logs"] = STATE["full_logs"][-800:]

def add_user_log(msg: str):
    with LOCK:
        STATE["user_logs"].append(msg)
        STATE["user_logs"] = STATE["user_logs"][-400:]

def reset_state_for_new_run(config):
    with LOCK:
        STATE["running"] = True
        STATE["full_logs"] = []
        STATE["user_logs"] = []
        STATE["current_config"] = config
        STATE["result_image_ready"] = False
        STATE["result_summary"] = None
        STATE["popup_open"] = False

def finish_state(summary=None):
    with LOCK:
        STATE["running"] = False
        STATE["result_summary"] = summary
        if os.path.exists(ms.PLACEMENT_DEBUG_IMG):
            STATE["result_image_ready"] = True
            STATE["popup_open"] = True

def validate_config(config):
    mode = int(config.get("mode", 0))
    if mode not in (1, 2):
        raise RuntimeError("Geçersiz mod.")

    valid_diodes = {"S3M", "SK510C"}
    valid_resistors = {"223", "331", "1001", "332"}

    if mode == 1:
        diode_map = config.get("diode_slot_map", {})
        resistor_map = config.get("resistor_map_mode1", {})

        if set(diode_map.keys()) != valid_diodes:
            raise RuntimeError("Mod 1 için diyot eşleşmesi eksik ya da hatalı.")

        if set(diode_map.values()) != {"D1", "D2"}:
            raise RuntimeError("Mod 1 için diyot slotları D1 ve D2 olmalı.")

        if len(resistor_map) != 2:
            raise RuntimeError("Mod 1 için 2 farklı direnç seçilmelidir.")

        if len(set(resistor_map.keys())) != 2:
            raise RuntimeError("Mod 1 için direnç değerleri tekrar etmemeli.")

        if not set(resistor_map.keys()).issubset(valid_resistors):
            raise RuntimeError("Mod 1 için geçersiz direnç kodu var.")

        if set(resistor_map.values()) != {"R1", "R2"}:
            raise RuntimeError("Mod 1 için direnç slotları R1 ve R2 olmalı.")

    elif mode == 2:
        resistor_map = config.get("resistor_map_mode2", {})

        if len(resistor_map) != 4:
            raise RuntimeError("Mod 2 için 4 farklı direnç seçilmelidir.")

        if set(resistor_map.keys()) != valid_resistors:
            raise RuntimeError("Mod 2 için tüm direnç kodları birer kez seçilmeli.")

        if set(resistor_map.values()) != {"D1", "D2", "R1", "R2"}:
            raise RuntimeError("Mod 2 için slotlar D1, D2, R1, R2 olmalı.")

def run_cycle_background(config):
    printer_dev = ms.SerialDevice(ms.PRINTER_PORT, ms.PRINTER_BAUD, timeout=0.2)
    arduino_dev = ms.SerialDevice(ms.ARDUINO_PORT, ms.ARDUINO_BAUD, timeout=1.0)
    nano_dev    = ms.SerialDevice(ms.NANO_PORT, ms.NANO_BAUD, timeout=1.0)

    try:
        ms.set_log_callbacks(add_full_log, add_user_log)

        printer = ms.Printer(printer_dev)
        arduino = ms.ArduinoActuator(arduino_dev)
        diode_tester = ms.DiodeTester(nano_dev)
        resistor_tester = ms.ResistorTester(nano_dev)

        add_user_log("Cihazlara bağlanılıyor...")
        printer.connect()
        arduino.connect()
        diode_tester.connect()
        resistor_tester.connect()

        add_user_log("Sistem başlatıldı.")
        result = ms.run_one_cycle_web(
            printer=printer,
            arduino=arduino,
            diode_tester=diode_tester,
            resistor_tester=resistor_tester,
            config=config
        )

        add_user_log("İşlem tamamlandı.")
        finish_state(summary=result)

    except Exception as e:
        add_full_log(f"[WEB RUN ERROR] {e}")
        add_full_log(traceback.format_exc())
        add_user_log(f"Hata oluştu: {e}")

        try:
            printer = ms.Printer(printer_dev)
            printer.go_safe_only()
            printer.go_home()
        except Exception:
            pass

        finish_state(summary={"error": str(e)})

    finally:
        try:
            printer_dev.close()
        except Exception:
            pass
        try:
            arduino_dev.close()
        except Exception:
            pass
        try:
            nano_dev.close()
        except Exception:
            pass

