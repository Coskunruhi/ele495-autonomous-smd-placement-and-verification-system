<script>
const ALL_RES = ["223", "331", "1001", "332"];
let prevRunning = false;
let overlayMode = null;

function setOptions(selectId, values) {
  const el = document.getElementById(selectId);
  const current = el.value;
  el.innerHTML = "";

  const noneOpt = document.createElement("option");
  noneOpt.value = "";
  noneOpt.textContent = "None";
  el.appendChild(noneOpt);

  values.forEach(v => {
    const opt = document.createElement("option");
    opt.value = v;
    opt.textContent = v;
    el.appendChild(opt);
  });

  if (["", ...values].includes(current)) {
    el.value = current;
  } else {
    el.value = "";
  }
}

function renderUserMessages(messages, targetEl) {
  targetEl.innerHTML = "";
  messages.forEach(msg => {
    const div = document.createElement("div");
    div.className = "user-msg";
    div.textContent = msg;
    targetEl.appendChild(div);
  });
}

function setSlot(slotId, valueText) {
  const slot = document.getElementById(slotId);
  const valueDiv = slot.querySelector(".slot-value");

  if (!valueText) {
    valueDiv.innerText = "Seçim yok";
    slot.classList.add("hint");
    slot.classList.remove("active");
    return;
  }

  valueDiv.innerText = valueText;
  slot.classList.remove("hint");
  slot.classList.add("active");
}

function resetFormToDefault() {
  document.getElementById("mode").value = "1";

  document.getElementById("d1_diode").value = "";
  document.getElementById("r1_res").value = "";
  document.getElementById("r2_res").value = "";

  document.getElementById("m2_d1").value = "";
  document.getElementById("m2_d2").value = "";
  document.getElementById("m2_r1").value = "";
  document.getElementById("m2_r2").value = "";

  updateModeFields();

  setSlot("slot_D1", "");
  setSlot("slot_D2", "");
  setSlot("slot_R1", "");
  setSlot("slot_R2", "");
}

function syncUniqueMode1() {
  const r1 = document.getElementById("r1_res").value;
  const r2 = document.getElementById("r2_res").value;

  setOptions("r1_res", ALL_RES.filter(v => v !== r2 || r1 === v));
  setOptions("r2_res", ALL_RES.filter(v => v !== r1 || r2 === v));

  document.getElementById("r1_res").value = r1 && (r1 !== r2 || r2 === "") ? r1 : (r1 === r2 ? "" : r1);
  document.getElementById("r2_res").value = r2 && (r2 !== r1 || r1 === "") ? r2 : (r1 === r2 ? "" : r2);
}

function syncUniqueMode2() {
  const ids = ["m2_d1", "m2_d2", "m2_r1", "m2_r2"];
  const selected = {};
  ids.forEach(id => selected[id] = document.getElementById(id).value);

  ids.forEach(id => {
    const usedByOthers = ids
      .filter(other => other !== id)
      .map(other => selected[other])
      .filter(v => v !== "");

    const current = selected[id];
    const allowed = ALL_RES.filter(v => !usedByOthers.includes(v) || v === current);

    setOptions(id, allowed);

    if (current && allowed.includes(current)) {
      document.getElementById(id).value = current;
    } else {
      document.getElementById(id).value = "";
    }
  });
}

function updateModeFields() {
  const mode = document.getElementById("mode").value;
  document.getElementById("mode1-fields").style.display = mode === "1" ? "block" : "none";
  document.getElementById("mode2-fields").style.display = mode === "2" ? "block" : "none";

  const mode1Warning = document.getElementById("mode1-warning");
  if (mode1Warning) {
    mode1Warning.style.display = mode === "1" ? "block" : "none";
  }

  if (mode === "1") {
    syncUniqueMode1();
  } else {
    syncUniqueMode2();
  }

  updatePcbLabels();
}

function updatePcbLabels() {
  const mode = document.getElementById("mode").value;

  if (mode === "1") {
    syncUniqueMode1();

    const d1 = document.getElementById("d1_diode").value;
    const d2 = d1 === "S3M" ? "SK510C" : (d1 === "SK510C" ? "S3M" : "");
    const r1 = document.getElementById("r1_res").value;
    const r2 = document.getElementById("r2_res").value;

    setSlot("slot_D1", d1);
    setSlot("slot_D2", d2);
    setSlot("slot_R1", r1);
    setSlot("slot_R2", r2);
  } else {
    syncUniqueMode2();

    setSlot("slot_D1", document.getElementById("m2_d1").value);
    setSlot("slot_D2", document.getElementById("m2_d2").value);
    setSlot("slot_R1", document.getElementById("m2_r1").value);
    setSlot("slot_R2", document.getElementById("m2_r2").value);
  }
}

function validateBeforeStart() {
  const mode = document.getElementById("mode").value;

  if (mode === "1") {
    const d1 = document.getElementById("d1_diode").value;
    const r1 = document.getElementById("r1_res").value;
    const r2 = document.getElementById("r2_res").value;

    if (!d1 || !r1 || !r2) {
      alert("Mod 1 için tüm seçimleri yapmalısın.");
      return false;
    }

    if (r1 === r2) {
      alert("Aynı direnç değeri iki slotta seçilemez.");
      return false;
    }
  } else {
    const vals = [
      document.getElementById("m2_d1").value,
      document.getElementById("m2_d2").value,
      document.getElementById("m2_r1").value,
      document.getElementById("m2_r2").value
    ];

    if (vals.some(v => !v)) {
      alert("Mod 2 için dört slotun da seçilmesi gerekiyor.");
      return false;
    }

    const uniqueVals = new Set(vals);
    if (uniqueVals.size !== 4) {
      alert("Mod 2 için aynı direnç değeri tekrar seçilemez.");
      return false;
    }
  }

  return true;
}

async function startSystem() {
  if (!validateBeforeStart()) {
    return;
  }

  const mode = document.getElementById("mode").value;
  let payload = { mode: mode };

  if (mode === "1") {
    const d1 = document.getElementById("d1_diode").value;
    const d2 = d1 === "S3M" ? "SK510C" : "S3M";

    payload.diode_slot_map = {};
    payload.diode_slot_map[d1] = "D1";
    payload.diode_slot_map[d2] = "D2";

    payload.resistor_map_mode1 = {
      [document.getElementById("r1_res").value]: "R1",
      [document.getElementById("r2_res").value]: "R2"
    };
  } else {
    payload.resistor_map_mode2 = {
      [document.getElementById("m2_d1").value]: "D1",
      [document.getElementById("m2_d2").value]: "D2",
      [document.getElementById("m2_r1").value]: "R1",
      [document.getElementById("m2_r2").value]: "R2"
    };
  }

  const res = await fetch("/start", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify(payload)
  });
  const data = await res.json();
  alert(data.message);
}

async function closePopup() {
  document.getElementById("imgModal").style.display = "none";
  try {
    await fetch("/close-popup", { method: "POST" });
  } catch (e) {
    console.error("Popup kapatma hatası:", e);
  }
}

function openPanelOverlay(type) {
  overlayMode = type;
  const overlay = document.getElementById("panelOverlay");
  const body = document.getElementById("overlayBody");
  const title = document.getElementById("overlayTitle");

  body.innerHTML = "";

  if (type === "user") {
    title.textContent = "Kullanıcı Mesajları";
    const div = document.createElement("div");
    div.className = "userlogs";
    div.id = "overlayUserLogs";
    body.appendChild(div);
  } else {
    title.textContent = "Tüm Loglar";
    const div = document.createElement("div");
    div.className = "logs";
    div.id = "overlayFullLogs";
    body.appendChild(div);
  }

  overlay.style.display = "flex";
}

function closePanelOverlay() {
  document.getElementById("panelOverlay").style.display = "none";
  document.getElementById("overlayBody").innerHTML = "";
  overlayMode = null;
}

async function pollStatus() {
  const res = await fetch("/status");
  const data = await res.json();

  document.getElementById("fulllogs").innerText = data.full_logs.join("\\n");
  renderUserMessages(data.user_logs, document.getElementById("userlogs"));

  const full = document.getElementById("fulllogs");
  full.scrollTop = full.scrollHeight;

  const user = document.getElementById("userlogs");
  user.scrollTop = user.scrollHeight;

  if (overlayMode === "user") {
    const overlayUser = document.getElementById("overlayUserLogs");
    if (overlayUser) {
      renderUserMessages(data.user_logs, overlayUser);
      overlayUser.scrollTop = overlayUser.scrollHeight;
    }
  }

  if (overlayMode === "log") {
    const overlayFull = document.getElementById("overlayFullLogs");
    if (overlayFull) {
      overlayFull.innerText = data.full_logs.join("\\n");
      overlayFull.scrollTop = overlayFull.scrollHeight;
    }
  }

  const runState = document.getElementById("runState");
  if (data.running) {
    runState.innerText = "Durum: Çalışıyor";
    runState.className = "statusline status-running";
  } else {
    runState.innerText = "Durum: Beklemede";
    runState.className = "statusline status-idle";
  }

  document.getElementById("startBtn").disabled = data.running;

  if (data.result_summary) {
    document.getElementById("summaryBox").innerText = JSON.stringify(data.result_summary, null, 2);
  } else {
    document.getElementById("summaryBox").innerText = "";
  }

  if (data.popup_open) {
    document.getElementById("imgModal").style.display = "flex";
    document.getElementById("resultImg").src = "/debug-image?ts=" + Date.now();
  }

  if (prevRunning === true && data.running === false) {
    resetFormToDefault();
  }

  prevRunning = data.running;

  setTimeout(pollStatus, 1000);
}

document.addEventListener("change", function() {
  updatePcbLabels();
});

document.addEventListener("keydown", function(e) {
  const modal = document.getElementById("imgModal");
  const overlay = document.getElementById("panelOverlay");

  if (e.key === "Escape") {
    if (modal.style.display === "flex") {
      closePopup();
      return;
    }
    if (overlay.style.display === "flex") {
      closePanelOverlay();
    }
  }
});

window.addEventListener("click", function(e) {
  const modal = document.getElementById("imgModal");
  const overlay = document.getElementById("panelOverlay");

  if (e.target === modal) {
    closePopup();
  }
  if (e.target === overlay) {
    closePanelOverlay();
  }
});

updateModeFields();
pollStatus();
</script>
</body>
</html>
