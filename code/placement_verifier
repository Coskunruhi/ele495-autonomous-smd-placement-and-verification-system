WEBCAM_INDEX    = 0
WEBCAM_WARMUP_S = 2.0

TM_METHOD = cv2.TM_CCOEFF_NORMED

GREEN_THRESH  = 75
YELLOW_THRESH = 55

ROI_W = 72
ROI_H = 84

MAX_ROT_DEG = 25

DIODE_SEARCH_PAD_X = 24
DIODE_SEARCH_PAD_Y = 24

RES_SEARCH_PAD_X = 14
RES_SEARCH_PAD_Y = 14

DIODE_MAX_SHIFT_PX = 26
RESISTOR_MAX_SHIFT_PX = 32

DIODE_ROT_PENALTY = 0.7
RESISTOR_ROT_PENALTY = 0.15

USE_ROTATION_FOR_RESISTOR = False

DIODE_TEMPLATE_WEIGHT = 0.75
DIODE_SHIFT_WEIGHT = 0.25

RES_TEMPLATE_WEIGHT = 0.45
RES_SHIFT_WEIGHT = 0.55

