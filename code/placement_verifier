BASE_DIR = "/home/pi/vision"

EMPTY_IMG = os.path.join(BASE_DIR, "empty_pcb.jpg")
TEST_IMG  = os.path.join(BASE_DIR, "test_pcb.jpg")

OUT_JSON  = os.path.join(BASE_DIR, "placement_result.json")
